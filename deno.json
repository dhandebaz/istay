{
  "$schema": "https://fresh.deno.dev/schemas/config.schema.json",
  "tasks": {
    "check": "deno check --unstable-cron --unstable-kv **/*.ts **/*.tsx",
    "start": "deno run -A --unstable-cron --unstable-kv --watch=static/,routes/ dev.ts",
    "build": "deno task db:generate && deno run -A --unstable-cron --unstable-kv dev.ts build",
    "preview": "deno run -A --unstable-cron --unstable-kv main.ts",
    "update": "deno run -A -r https://fresh.deno.dev/update .",
    "db:generate": "mkdir -p node_modules/@prisma/client && echo '{\"name\":\"@prisma/client\",\"version\":\"6.4.1\"}' > node_modules/@prisma/client/package.json && PRISMA_GENERATE_SKIP_AUTOINSTALL=true deno run -A npm:prisma@6.4.1 generate",
    "db:push": "deno run -A npm:prisma@6.4.1 db push"
  },
  "nodeModulesDir": "auto",
  "lint": {
    "rules": {
      "tags": ["fresh", "recommended"]
    }
  },
  "exclude": ["**/_fresh/*", "node_modules"],
  "imports": {
    "$fresh/": "https://deno.land/x/fresh@1.7.3/",
    "preact": "https://esm.sh/preact@10.22.0",
    "preact/": "https://esm.sh/preact@10.22.0/",
    "@preact/signals": "https://esm.sh/@preact/signals@1.2.3",
    "@preact/signals-core": "https://esm.sh/@preact/signals-core@1.5.1",
    "twind": "https://esm.sh/twind@0.16.19",
    "twind/": "https://esm.sh/twind@0.16.19/",
    "s3_lite_client": "https://deno.land/x/s3_lite_client@0.7.0/mod.ts",
    "@prisma/client": "./generated/client/deno/edge.ts",
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@6.4.1",
    "pg": "npm:pg@8.13.3"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns",
      "deno.unstable"
    ]
  }
}
