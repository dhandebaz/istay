// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "deno"]
  output          = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── CORE ENTITIES ─────────────────────────────────────────────

model Host {
  id                     String    @id @default(uuid())
  email                  String    @unique
  name                   String
  phone                  String
  plan                   String    @default("monthly") // "monthly" or "lifetime"
  subscriptionStatus     String    @default("expired") // "active", "expired", "trailing"
  subscriptionExpiresAt  DateTime?
  walletBalance          Float     @default(0)
  setupFeePaid           Boolean   @default(false)
  gatewayVendorId        String?
  cashfreeVendorId       String?
  razorpaySubscriptionId String?
  lastLowBalanceAlert    DateTime?
  apiKey                 String?
  legacyApiKey           String?
  legacyApiKeyExpires    DateTime?
  settings               Json? // logoUrl, gstin, businessName, etc.
  webhooks               Json? // Array of WebhookConfig
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  auth               AuthRecord?
  properties         Property[]
  bookings           Booking[]
  ledgerEntries      LedgerEntry[]
  notifications      Notification[]
  knowledge          HostKnowledge[]
  walletTransactions WalletTransaction[]
}

model WalletTransaction {
  id          String   @id @default(uuid())
  hostId      String
  amount      Float // Positive for top-up, negative for usage
  type        String // "topup", "ai_usage"
  description String
  meta        Json? // { tokens: { in, out }, model, etc. }
  createdAt   DateTime @default(now())

  host Host @relation(fields: [hostId], references: [id])
}

model AuthRecord {
  hostId            String    @id
  email             String    @unique
  passwordHash      String
  salt              String
  role              String    @default("owner")
  emailVerified     Boolean   @default(false)
  verifyToken       String?
  resetToken        String?
  resetTokenExpires DateTime?

  host Host @relation(fields: [hostId], references: [id])
}

model Property {
  id              String   @id @default(uuid())
  hostId          String
  name            String
  description     String
  imageUrl        String
  airbnbUrl       String?
  basePrice       Float
  status          String   @default("pending")
  address         String?
  amenities       String[]
  icalUrl         String?
  caretakerToken  String?  @unique
  caretakerPhone  String?
  caretakerName   String?
  pricingSettings Json? // weekendSurcharge, seasonalAdjustments, etc.
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  host      Host            @relation(fields: [hostId], references: [id])
  bookings  Booking[]
  blocks    CalendarBlock[]
  reviews   Review[]
  knowledge HostKnowledge[]
}

model Booking {
  id                String   @id @default(uuid())
  propertyId        String
  hostId            String
  guestName         String
  guestEmail        String
  guestPhone        String?
  guestIdRef        String?
  checkIn           DateTime
  checkOut          DateTime
  nights            Int
  amount            Float
  status            String   @default("pending")
  gatewayOrderId    String?
  paymentSessionId  String?
  idVerified        Boolean  @default(false)
  caretakerPhone    String?
  caretakerName     String?
  checkoutChecklist Json?
  cleanProofUrl     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  property      Property           @relation(fields: [propertyId], references: [id])
  host          Host               @relation(fields: [hostId], references: [id])
  ledgerEntries LedgerEntry[]
  verification  GuestVerification?
}

model CalendarBlock {
  id         String   @id @default(uuid())
  propertyId String
  date       DateTime // Store specifically as date
  reason     String // booked, manual_block, ical
  bookingId  String?

  property Property @relation(fields: [propertyId], references: [id])
}

model LedgerEntry {
  id             String    @id @default(uuid())
  bookingId      String
  hostId         String
  propertyId     String
  gatewayOrderId String
  grossAmount    Float
  hostAmount     Float
  istayAmount    Float
  status         String    @default("pending")
  settledAt      DateTime?
  createdAt      DateTime  @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  host    Host    @relation(fields: [hostId], references: [id])
}

model Notification {
  id           String   @id @default(uuid())
  hostId       String
  type         String
  title        String
  message      String
  propertyName String
  meta         Json?
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())

  host Host @relation(fields: [hostId], references: [id])
}

model GuestVerification {
  bookingId     String    @id
  guestName     String
  idType        String
  idObjectKey   String?
  status        String    @default("pending")
  extractedData Json? // name, idLast4, dob, etc.
  matchScore    Int?
  flags         String[]
  createdAt     DateTime  @default(now())
  verifiedAt    DateTime?

  booking Booking @relation(fields: [bookingId], references: [id])
}

model Review {
  id          String   @id @default(uuid())
  propertyId  String
  bookingId   String?
  guestName   String
  rating      Int
  comment     String
  source      String   @default("direct") // direct, imported
  sourceLabel String
  createdAt   DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id])
}

model GuestProfile {
  phone       String   @id
  names       String[]
  emails      String[]
  preferences String[]
  summary     String?
  stayHistory Json? // Array of stay objects
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HostKnowledge {
  id         String   @id @default(uuid())
  hostId     String
  propertyId String
  content    String
  updatedAt  DateTime @updatedAt

  host     Host     @relation(fields: [hostId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
}

model Waitlist {
  id        String   @id @default(uuid())
  email     String
  phone     String
  interest  String?
  createdAt DateTime @default(now())
}
