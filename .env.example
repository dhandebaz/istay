# ================================================================
# istay.space — Environment Variables
# ================================================================

# ── Payment (Cashfree) ─────────────────────────────────────────
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=sandbox
# sandbox or production

# Cashfree webhook signature secret (for payment verification)
CASHFREE_WEBHOOK_SECRET=your_webhook_secret

# ── AI (Google Gemini) ─────────────────────────────────────────
# Get your free API key from: https://aistudio.google.com/apikey
# Model: gemini-2.0-flash-lite ($0.075/1M input tokens)
GEMINI_API_KEY=your_gemini_api_key

# ── Internal ───────────────────────────────────────────────────
# Optional: protects the manual /api/cron/sync endpoint
CRON_SECRET=your_cron_secret

# ── WhatsApp Business API (Concierge Bridge) ──────────────────
# Required to receive and reply to guest messages on WhatsApp.
# Create a Meta Business app, then get these from the WhatsApp API dashboard.
WHATSAPP_VERIFY_TOKEN=istay-verify-token
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id

# Public-facing base URL (used for payment return URLs)
APP_BASE_URL=http://localhost:8000

# ── Cloudflare R2 (Object Storage) ─────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_BUCKET_NAME=istay
R2_S3_ACCESS_KEY=your_access_key
R2_S3_SECURITY_ACCESS_KEY=your_secret_key
R2_S3_URL_ENDPOINT=https://your_id.r2.cloudflarestorage.com
